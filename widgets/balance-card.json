{
  "type": "AdaptiveCard",
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "HematYuk!",
      "weight": "Bolder",
      "size": "Medium",
      "color": "Good"
    },
    {
      "type": "TextBlock",
      "text": "Total Saldo",
      "isSubtle": true,
      "size": "Small"
    },
    {
      "type": "TextBlock",
      "text": "${balance}",
      "weight": "Bolder",
      "size": "Large",
      "color": "Good"
    },
    {
      "type": "ColumnSet",
      "columns": [
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            { "type": "TextBlock", "text": "Masuk", "isSubtle": true, "size": "Small" },
            { "type": "TextBlock", "text": "${income}", "color": "Good", "weight": "Bolder" }
          ]
        },
        {
          "type": "Column",
          "width": "stretch",
          "items": [
            { "type": "TextBlock", "text": "Keluar", "isSubtle": true, "size": "Small" },
            { "type": "TextBlock", "text": "${expense}", "color": "Attention", "weight": "Bolder" }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "Buka HematYuk",
      "url": "https://javellindavid.github.io/HematYuk/"
    }
  ]
}
