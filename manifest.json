{
  "id": "./",
  "name": "HematYuk",
  "short_name": "HematYuk",
  "description": "Aplikasi manajemen inventaris dan keuangan pintar untuk pelaku usaha kecil. Pantau stok, catat transaksi, dan kelola bisnis dengan mudah.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["tabbed", "window-controls-overlay", "standalone", "minimal-ui", "browser"],
  "dir": "ltr",
  "background_color": "#059669",
  "theme_color": "#059669",
  "orientation": "portrait",
  "lang": "id",
  "prefer_related_applications": false,
  "related_applications": [],
  "iarc_rating_id": "",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "note_taking": {
    "new_note_url": "./index.html?action=new-note"
  },
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+hematyuk",
      "url": "./index.html?action=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/json": [".json"],
        "text/plain": [".txt", ".csv"]
      },
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ],
  "scope_extensions": [],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "widgets": [
    {
      "name": "HematYuk Saldo",
      "description": "Widget ringkasan saldo keuangan HematYuk",
      "tag": "hematyuk-balance-widget",
      "ms_ac_template": "widgets/balance-card.json",
      "data": "widgets/balance-data.json",
      "type": "application/json",
      "screenshots": [
        {
          "src": "icons/screenshot1.png",
          "sizes": "1442x3090",
          "label": "HematYuk balance widget preview"
        }
      ],
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "auth": false,
      "update": 3600
    }
  ],
  "icons": [
    {
      "src": "icons/icon-192x192-A.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "icons/icon-512x512-B.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "screenshots": [
    {
      "src": "icons/screenshot1.png",
      "sizes": "1442x3090",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "icons/screenshot2.png",
      "sizes": "1442x3090",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "icons/screenshot3.png",
      "sizes": "1920x1080",
      "type": "image/png",
      "form_factor": "wide"
    }
  ],
  "shortcuts": [
    {
      "name": "Buka Beranda",
      "short_name": "Beranda",
      "url": "./index.html",
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png",
          "purpose": "maskable any"
        }
      ]
    },
    {
      "name": "Tambah Transaksi",
      "short_name": "Transaksi",
      "url": "./index.html?page=keuangan",
      "description": "Catat transaksi keuangan baru",
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Kelola Produk",
      "short_name": "Produk",
      "url": "./index.html?page=produk",
      "description": "Kelola inventaris produk",
      "icons": [
        {
          "src": "icons/icon-192x192-A.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "categories": [
    "finance",
    "productivity",
    "business"
  ]
}